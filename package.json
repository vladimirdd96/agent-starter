{
  "name": "agent-starter",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-optimized project foundation — clone and extend per project",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "docs:list": "grep -r 'read_when' docs/ --include='*.md' -l"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@commitlint/types": "^19.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.5.0",
    "zod": "^3.23.0"
  },
  "lint-staged": {
    "*.ts?(x)": [
      "eslint --fix",
      "bash -c 'npm run typecheck'"
    ]
  }
}
